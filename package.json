{
    "name": "axis-gateway-plugin",
    "version": "1.0.0",
    "description": "Elgato Stream Deck plugin — control Axis cameras via the CamScripter Stream Deck Gateway (Phase 1)",
    "type": "module",
    "author": "Pavel Kotyza",
    "license": "MIT",
    "scripts": {
        "build": "rollup -c",
        "watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.4xsdev.axis-gateway\""
    },
    "dependencies": {
        "@elgato/streamdeck": "^1.2.0"
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "^28.0.0",
        "@rollup/plugin-node-resolve": "^16.0.0",
        "@rollup/plugin-typescript": "^12.1.0",
        "@types/node": "^20.16.0",
        "rollup": "^4.24.0",
        "tslib": "^2.7.0",
        "typescript": "^5.6.0"
    }
}
